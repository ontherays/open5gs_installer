# =============================================================================
#  Open5GS Core - configuration
#
#  This is the single place you edit to adapt the deployment to your lab.
#  The shell scripts read everything from here, so you should rarely need to
#  touch the *.sh files themselves. Copy this repo, tweak this file, done.
#
#  Every value uses the ${VAR:-default} form, which means you can also override
#  any of them inline without editing the file, e.g.:
#      MODE=external SUB_COUNT=50 ./start.sh
# =============================================================================

# --- Deployment mode ---------------------------------------------------------
#   local    : every network function binds to loopback (127.0.0.x). Best for a
#              self-contained, single-box core (gNB/UE simulators on the same
#              machine, or RF simulator).
#   external : the radio-facing functions (AMF N2, UPF N3, plus the 4G MME/SGW-U)
#              bind to this host's physical IP so a *separate* gNB can reach them.
#              A virtual IP is also added to the NIC to give the gNB link a
#              stable target.
MODE=${MODE:-local}

# --- PLMN / slice identity ---------------------------------------------------
#   These must match your gNB configuration and the SIM/UE profiles.
MCC=${MCC:-001}            # mobile country code
MNC=${MNC:-01}            # mobile network code
TAC=${TAC:-1}            # tracking area code
SST=${SST:-1}            # default slice type (OCUDU / OAI gNB advertises sst=1)
DNN=${DNN:-internet}     # data network name (a.k.a. APN)

# --- UE address pool (handed out by the UPF) --------------------------------
UE_SUBNET=${UE_SUBNET:-10.45.0.0/16}
UE_GW=${UE_GW:-10.45.0.1}
DNS1=${DNS1:-8.8.8.8}
DNS2=${DNS2:-8.8.4.4}

# --- Networking --------------------------------------------------------------
#   Leave INF / NODE_IP empty to auto-detect the default-route interface and
#   its primary IPv4 address. Set them explicitly if auto-detection picks the
#   wrong NIC (common on multi-homed lab servers).
INF=${INF:-}
NODE_IP=${NODE_IP:-}
#   Virtual IP used for the gNB link in external mode. Empty => NODE_IP with the
#   last octet incremented by one.
VNF_VI_IP=${VNF_VI_IP:-}

# --- WebUI -------------------------------------------------------------------
#   Bound to loopback in local mode and 0.0.0.0 in external mode. Default login
#   is admin / 1423 (auto-created by the WebUI on first run). CHANGE IT.
WEBUI_PORT=${WEBUI_PORT:-9999}

# --- Build pins (reproducibility) -------------------------------------------
OPEN5GS_GIT_REF=${OPEN5GS_GIT_REF:-10b161fbb9dd81c63a29caa9d599fc50edb64e27}
MONGODB_VERSION=${MONGODB_VERSION:-8.0}
NODE_VERSION=${NODE_VERSION:-16.20.2}

# --- Test SIM credentials ----------------------------------------------------
#   These are the PUBLIC Open5GS / srsRAN test vectors. They are NOT secret and
#   are safe to keep in a lab repo. For over-the-air use with real cards,
#   replace them with the Ki / OPc printed on (or programmed into) your SIMs.
SIM_K=${SIM_K:-8baf473f2f8fd09487cccbd7097c6862}
SIM_OPC=${SIM_OPC:-8e27b6af0e692e750f32667a3b14605d}
SIM_AMF=${SIM_AMF:-8000}

# --- Subscriber seeding (the "counter") -------------------------------------
#   add-subscribers.sh generates SUB_COUNT consecutive IMSIs starting at
#   SUB_IMSI_BASE. This replaces the old hand-maintained insertMany() blob.
SUB_IMSI_BASE=${SUB_IMSI_BASE:-001010000000001}
SUB_COUNT=${SUB_COUNT:-10}
SUB_PDU_TYPE=${SUB_PDU_TYPE:-3}   # 1=IPv4, 2=IPv6, 3=IPv4v6
